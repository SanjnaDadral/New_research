# Django Settings
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# Email Configuration (Required for email reports)
# For Gmail: Use App Password instead of your regular password
# Get it at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=PaperAIzer <noreply@paperyzer.ai>

# PDF Processing
PDF_MAX_PAGES=25
PDF_PREFER_FAST=True
LARGE_PDF_SKIP_PLUMBER_MB=12

# ML Processing
ANALYSIS_TEXT_MAX=50000
ANALYSIS_TEXT_CAP=50000
ENABLE_HEAVY_ML=False

# File Upload Limits
MAX_PDF_UPLOAD_MB=45
MAX_STORE_PDF_MB=16

# Security
ALLOWED_HOSTS=localhost,127.0.0.1
